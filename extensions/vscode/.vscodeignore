# bot-relay-mcp Tether VSCode extension — packaging exclusions.
#
# v0.1.4 esbuild bundling: pre-bundle this file excluded node_modules/**
# selectively (maps, test fixtures, .github metadata, etc). Now that
# esbuild rolls @modelcontextprotocol/sdk into out/extension.js, we can
# exclude node_modules/** wholesale.
#
# What ships in the VSIX:
#   - out/extension.js                  (bundled CJS, ~MCP SDK inlined)
#   - out/extension.js.map              (source map for debugging — Q1: YES)
#   - package.json                      (extension manifest)
#   - LICENSE, README.md, CHANGELOG.md  (Marketplace surface)
#
# What does NOT ship:
#   - node_modules/**                   (bundled away)
#   - src/**                            (bundled away; source lives in repo)
#   - any test files                    (.test.ts at any path)
#   - bundler/typecheck configs         (esbuild.config.mjs, tsconfig.json)
#   - prior VSIX artifacts              (*.vsix)
#   - dev-internal docs                 (PUBLISH.md, marketplace-prep-results.md)
#   - editor/OS junk                    (.vscode/, .DS_Store, etc)
#
# NOTE: we deliberately do NOT add a blanket `**/*.map` exclusion. That
# was correct pre-bundling (when node_modules shipped) because every
# transitive dep's .map files were ~50% of VSIX bytes. With node_modules
# excluded wholesale, the only .map left is our intentional
# out/extension.js.map — which we WANT for debug-friendliness.

# Source + build inputs
src/**
tsconfig.json
esbuild.config.mjs
.gitignore

# Bundled-away — no runtime need
node_modules/**

# esbuild metafile — test-only ground truth, never read by the runtime
# extension. Keeps ~155 KB out of the VSIX without losing the bundle
# correctness drift guard (the metafile is read from disk in
# src/v0-1-4-bundle.test.ts, which runs from out/ inside the source
# repo, not from the VSIX).
out/extension.meta.json

# Tests + test config (vitest)
**/*.test.ts
**/*.test.js
vitest.config.*

# Internal docs (developer-facing only — not for marketplace)
PUBLISH.md
marketplace-prep-results.md

# Don't ship the package output itself if a prior `vsce package` left one behind
*.vsix

# Editor + OS junk
.vscode/**
.DS_Store
**/.DS_Store

# Package-lock — npm install side info, not extension runtime
package-lock.json
